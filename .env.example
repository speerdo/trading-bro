# ====================================================================
# TradeBrain — Environment Variables
# ====================================================================
# Required keys (cannot start without these):
#   OPENROUTER_API_KEY    — Kimi K2.6 signal evaluation
#   COINBASE_API_KEY      — CDP key name (organizations/{org}/apiKeys/{key})
#   COINBASE_API_SECRET   — CDP EC private key PEM (replace \n in .env)
#   DATABASE_URL          — Neon Postgres connection string
# -------------------------------------------------------------------

OPENROUTER_API_KEY=sk-or-...
COINBASE_API_KEY=organizations/.../apiKeys/...
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"
DATABASE_URL=postgresql://...

# Discord (optional but recommended for notifications)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Trading defaults (overridable in the UI)
PAPER_TRADING=true
DEFAULT_LEVERAGE=3
DEFAULT_RISK_PER_TRADE=0.01
DEFAULT_DAILY_LOSS_LIMIT=0.05
DEFAULT_STRATEGY=rsi_macd
DEFAULT_SIGNAL_INTERVAL=300
DEFAULT_MAX_WATCHLIST=5
