# ====================================================================
# ENV VARIABLE SUMMARY
# ====================================================================
# - Required: OPENROUTER_API_KEY, HL_WALLET_ADDRESS, HL_API_PRIVATE_KEY, DATABASE_URL
# - Required for Burt: DISCORD_BOT_TOKEN, DISCORD_CHANNEL_ID, DISCORD_USER_ID
# - Optional: DISCORD_WEBHOOK_URL, MOONDEV_API_KEY
# ====================================================================

OPENROUTER_API_KEY=sk-or-...
# HL_WALLET_ADDRESS=0x...
# HL_API_PRIVATE_KEY=0x...
DATABASE_URL=postgresql://...

# DISCORD_BOT_TOKEN=...
# DISCORD_CHANNEL_ID=...
# DISCORD_USER_ID=...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# MOONDEV_API_KEY=...

PAPER_TRADING=true
DEFAULT_LEVERAGE=3
DEFAULT_RISK_PER_TRADE=0.01
DEFAULT_DAILY_LOSS_LIMIT=0.05
DEFAULT_STRATEGY=rsi_macd
DEFAULT_SIGNAL_INTERVAL=300
DEFAULT_MAX_WATCHLIST=5
HL_TESTNET=false
BURT_ACTIVE_HOURS_START=6
BURT_ACTIVE_HOURS_END=22
